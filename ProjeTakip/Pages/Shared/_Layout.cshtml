<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjeTakip</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjeTakip.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">ProjeTakip</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Gizlilik</a>
                        </li>
                    </ul>
                    
                    @if (Context.Session.GetString("UserId") != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Hoşgeldiniz, @Context.Session.GetString("UserName")
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><span class="dropdown-item-text"><strong>Kimlik:</strong> @Context.Session.GetString("UserKimlik")</span></li>
                                    <li><span class="dropdown-item-text"><strong>Rol:</strong> 
                                        @{
                                            var userRole = Context.Session.GetInt32("UserRole") ?? 0;
                                            if (userRole == 1)
                                            {
                                                <span class="badge bg-danger">Sistem Yöneticisi</span>
                                            }
                                            else if (userRole == 2)
                                            {
                                                <span class="badge bg-warning">Proje Yöneticisi</span>
                                            }
                                            else if (userRole == 3)
                                            {
                                                <span class="badge bg-info">Proje Uzmanı</span>
                                            }
                                            else if (userRole == 4)
                                            {
                                                <span class="badge bg-success">Departman Sorumlusu</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Kullanıcı</span>
                                            }
                                        }
                                    </span></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Login">Çıkış Yap</a></li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        @* <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Login">Giriş Yap</a>
                            </li>
                        </ul> *@
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ProjeTakip - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>